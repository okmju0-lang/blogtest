# AX 블로그 에이전트 — 환경 변수 설정 예시
# 이 파일을 복사하여 .env로 저장하고 실제 키를 입력하세요.

# Tavily API (팩트체크용)
# https://app.tavily.com/ 에서 발급
TAVILY_API_KEY=your_tavily_api_key_here

# Google AI API (Nano Banana 2 이미지 생성 전용)
# https://aistudio.google.com/ 에서 발급
# 포스트당 API 호출 3회: 썸네일 1 + 일러스트 2
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# Maily API (블로그 포스트 발송용)
# https://maily.so 에서 발급
MAILY_API_KEY=your_maily_api_key_here

# 스티비(Stibee) API (이메일 뉴스레터 발송용)
# 워크스페이스 설정 > API 키에서 생성 (2025-01-21 이후 생성 키만 유효)
# 프로/엔터프라이즈 요금제 필요
STIBEE_API_KEY=your_stibee_api_key_here
STIBEE_LIST_ID=your_list_id_here
STIBEE_SENDER_EMAIL=your_sender@example.com
STIBEE_SENDER_NAME=your_sender_name_here
