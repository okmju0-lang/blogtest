# AX 블로그 에이전트 — 환경 변수 설정 예시
# 이 파일을 복사하여 .env로 저장하고 실제 키를 입력하세요.

# Tavily API (팩트체크용)
# https://app.tavily.com/ 에서 발급
TAVILY_API_KEY=your_tavily_api_key_here

# Google AI API (Nano Banana 2 이미지 생성 전용)
# https://aistudio.google.com/ 에서 발급
# 포스트당 API 호출 3회: 썸네일 1 + 일러스트 2
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# imgbb API (블로그 이미지 호스팅용)
# https://api.imgbb.com/ 에서 무료 발급 (회원가입 후 API 키 생성)
# 블로그 발행 시 로컬 이미지를 imgbb에 업로드하여 외부 URL로 변환
IMGBB_API_KEY=your_imgbb_api_key_here

# 블로그 발행 API 주소
# 현재 운영 중인 블로그 어드민 배포 주소로 설정하세요.
BLOG_API_BASE=https://magicecole.vercel.app/api/blog

# 선택 사항: 상세 페이지/어드민 링크를 별도 도메인으로 출력할 때 사용
BLOG_SITE_BASE=https://magicecole.vercel.app
