# AX 블로그 에이전트 — 환경 변수 설정 예시
# 이 파일을 복사하여 .env로 저장하고 실제 키를 입력하세요.

# Tavily API (팩트체크용)
# https://app.tavily.com/ 에서 발급
TAVILY_API_KEY=your_tavily_api_key_here

# Google AI API (Gemini 이미지 생성용 — Nano Banana 2)
# https://aistudio.google.com/ 에서 발급
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# Stibee API (이메일 발송용)
# https://stibee.com/ 에서 발급
STIBEE_API_KEY=your_stibee_api_key_here
